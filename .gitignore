# Root .gitignore for CloudBox

# Dependency directories
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment files
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Build outputs
dist/
backend/dist/
frontend/dist/

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*

# Temporary files
tmp/
temp/
